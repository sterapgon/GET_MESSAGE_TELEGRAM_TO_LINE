# ── Telegram (Telethon user session) ──────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org → "API development tools"
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# The chat/channel/group where your bot posts messages.
# Accepts: @username, https://t.me/xxx, or numeric ID (e.g. -100123456789)
TELEGRAM_CHAT_ID=@your_channel

# Your bot's username WITHOUT the @ sign
TELEGRAM_BOT_USERNAME=your_bot_name

# (Optional) Filename for the Telethon session — default: telegram_session
# TELEGRAM_SESSION=telegram_session

# ── LINE Messaging API ─────────────────────────────────────────────────────────
# Channel Access Token from LINE Developers Console → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# Target to push messages to. Get via LINE webhook or /profile API.
# userId  → individual user  (starts with U)
# groupId → group chat       (starts with C)
# roomId  → multi-person chat (starts with R)
LINE_TARGET_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional tweaks ────────────────────────────────────────────────────────────
# Set to 1 to print messages without actually sending to LINE
# DRY_RUN=0

# จำนวนข้อความสูงสุดต่อ 1 รอบ (ป้องกันเกินโควต้า LINE free plan 200/เดือน)
# ตั้งเป็น 0 เพื่อไม่จำกัด
# MAX_MESSAGES_PER_RUN=50

# Delay ระหว่างส่งแต่ละข้อความ (วินาที) — ป้องกัน LINE 429
# LINE_SEND_DELAY=1.0

# Custom path for state file (default: state.json in cwd)
# STATE_FILE=state.json
